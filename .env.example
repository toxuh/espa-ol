# Development defaults only. Use a unique secret and a container-host URL in production.
DATABASE_URL="postgresql://espanol_diario:espanol_diario@localhost:5432/espanol_diario?schema=public"
POSTGRES_DB="espanol_diario"
POSTGRES_USER="espanol_diario"
POSTGRES_PASSWORD="espanol_diario"
POSTGRES_PORT="5432"
APP_TIMEZONE="Europe/Madrid"
NEXT_PUBLIC_APP_NAME="Español Diario"

# Production-only Traefik values
TRAEFIK_HOST="espanol.example.internal"
TRAEFIK_NETWORK="traefik"
TRAEFIK_ENTRYPOINT="websecure"
TRAEFIK_CERT_RESOLVER=""
